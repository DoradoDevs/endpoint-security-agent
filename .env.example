# Endpoint Security Agent — example environment configuration
#
# Copy this file to `.env` and fill in only what you need. Everything here is
# OPTIONAL — the agent runs fully offline with zero configuration. NEVER commit
# your real `.env` (it is gitignored).
#
# NOTE: These two variables are the only settings the agent reads from the
# environment. Other integrations (NVD/OTX API keys, SMTP email delivery,
# threat-intel feed keys) are configured through the agent's own config, not
# through environment variables — see SETUP.md and pass them via the relevant
# CLI flags / config file (default: ~/.sentinel or the platform config dir).

# --- License signing (optional; open-core builds only) ---
# HMAC key used to sign/verify optional license tokens. The open-source build
# does NOT gate any functionality behind a paid tier, so you can leave this
# blank. If you build a paid edition, set a strong random value and keep it off
# the client machines that only need to verify tokens.
ENDPOINT_AGENT_LICENSE_KEY=

# --- Auto-updater (optional) ---
# Base URL of YOUR OWN release-metadata server. There is no default: if this is
# unset, the auto-updater is a safe no-op. Only set it if you host signed
# release metadata for your own distribution of the agent.
ENDPOINT_AGENT_UPDATE_URL=
